<?xml version="1.0" encoding="utf-8"?>
<!--
  BeebOwl icon — an amber owl with a BBC-green CRT screen on its belly.
  Viewport 108×108; safe zone 18–90 in both axes.

  Design deliberately distinguishes from the original Beebdroid:
    • Warm amber body (BBC amber monitor palette), not Android green
    • Feathered ear tufts, not circular antenna balls
    • Pear-shaped body (not rectangular Android torso)
    • Belly CRT screen showing ">_" BBC Micro prompt
    • No visible arm-stubs — broad rounded wings instead
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Wings ──────────────────────────────────────────────────────────
         Drawn first so the body edge naturally overlaps their inner curves. -->
    <path
        android:fillColor="#9A6008"
        android:pathData="M36,76 C26,70 20,86 33,93 L36,90 C34,84 34,79 36,76 Z"/>
    <path
        android:fillColor="#9A6008"
        android:pathData="M72,76 C82,70 88,86 75,93 L72,90 C74,84 74,79 72,76 Z"/>

    <!-- ── Body: amber pear-shape ──────────────────────────────────────── -->
    <path
        android:fillColor="#C07808"
        android:pathData="M36,76 C36,63 72,63 72,76 C72,90 64,96 54,96 C44,96 36,90 36,76 Z"/>

    <!-- ── Head: large amber circle (cx=54 cy=48 r=26) ────────────────── -->
    <path
        android:fillColor="#D48A0C"
        android:pathData="M28,48 A26,26 0 0,1 80,48 A26,26 0 0,1 28,48 Z"/>

    <!-- ── Ear tufts — pointed feather tufts, not antenna balls ───────── -->
    <!-- Left tuft -->
    <path
        android:fillColor="#5C3800"
        android:pathData="M36,33 L41,19 L47,31 Z"/>
    <path
        android:fillColor="#7A4C00"
        android:pathData="M38,32 L41,21 L45,30 Z"/>
    <!-- Right tuft (mirror about x=54) -->
    <path
        android:fillColor="#5C3800"
        android:pathData="M72,33 L67,19 L61,31 Z"/>
    <path
        android:fillColor="#7A4C00"
        android:pathData="M70,32 L67,21 L63,30 Z"/>

    <!-- ── Left eye (cx=42 cy=46): socket → white → pupil → shine ─────── -->
    <!-- Socket — 1dp dark ring visible around the white -->
    <path
        android:fillColor="#2A1500"
        android:pathData="M31,46 A11,11 0 0,1 53,46 A11,11 0 0,1 31,46 Z"/>
    <!-- Sclera -->
    <path
        android:fillColor="#F2E8D0"
        android:pathData="M32,46 A10,10 0 0,1 52,46 A10,10 0 0,1 32,46 Z"/>
    <!-- Pupil (cx=43 cy=47 — shifted slightly toward viewer centre) -->
    <path
        android:fillColor="#0C0800"
        android:pathData="M37,47 A6,6 0 0,1 49,47 A6,6 0 0,1 37,47 Z"/>
    <!-- Specular shine -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,43 A2,2 0 0,1 42,43 A2,2 0 0,1 38,43 Z"/>

    <!-- ── Right eye (cx=66 cy=46) ─────────────────────────────────────── -->
    <path
        android:fillColor="#2A1500"
        android:pathData="M55,46 A11,11 0 0,1 77,46 A11,11 0 0,1 55,46 Z"/>
    <path
        android:fillColor="#F2E8D0"
        android:pathData="M56,46 A10,10 0 0,1 76,46 A10,10 0 0,1 56,46 Z"/>
    <!-- Pupil (cx=65 cy=47 — shifted slightly toward viewer centre) -->
    <path
        android:fillColor="#0C0800"
        android:pathData="M59,47 A6,6 0 0,1 71,47 A6,6 0 0,1 59,47 Z"/>
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M60,43 A2,2 0 0,1 64,43 A2,2 0 0,1 60,43 Z"/>

    <!-- ── Beak: downward triangle between + below the eyes ───────────── -->
    <path
        android:fillColor="#F0A018"
        android:pathData="M50,57 L54,64 L58,57 Z"/>
    <!-- Small beak highlight -->
    <path
        android:fillColor="#FFCC40"
        android:pathData="M51,57 L54,61 L57,57 Z"/>

    <!-- ── Belly CRT screen ────────────────────────────────────────────── -->
    <!-- Bezel (rounded rect x=40–68 y=70–90, 2dp corner radius) -->
    <path
        android:fillColor="#182818"
        android:pathData="M42,70 Q40,70 40,72 L40,88 Q40,90 42,90 L66,90 Q68,90 68,88 L68,72 Q68,70 66,70 Z"/>
    <!-- Dark glass -->
    <path
        android:fillColor="#030C03"
        android:pathData="M42,72 L66,72 L66,88 L42,88 Z"/>
    <!-- BBC-green ">" prompt (right-pointing triangle) -->
    <path
        android:fillColor="#28B838"
        android:pathData="M44,76 L48,81 L44,86 Z"/>
    <!-- BBC-green "_" blinking cursor -->
    <path
        android:fillColor="#28B838"
        android:pathData="M49,85 L57,85 L57,86.5 L49,86.5 Z"/>

    <!-- ── Chest feather rows (visible between beak and screen) ───────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#A06808"
        android:strokeWidth="1.2"
        android:pathData="M40,66 Q54,63 68,66"/>
    <path
        android:fillColor="#00000000"
        android:strokeColor="#A06808"
        android:strokeWidth="1.2"
        android:pathData="M39,70 Q54,67 69,70"/>

    <!-- ── Toe claws (three per foot, within safe zone) ──────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#6A4000"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M46,94 L42,102 M46,94 L46,102 M46,94 L50,102"/>
    <path
        android:fillColor="#00000000"
        android:strokeColor="#6A4000"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M62,94 L58,102 M62,94 L62,102 M62,94 L66,102"/>

</vector>
